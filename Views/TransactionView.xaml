<UserControl x:Class="QuanLyTaiChinhCaNhan_Nhom06.Views.TransactionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <UserControl.Resources>
        <Style x:Key="TransactionCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="15"/>
        </Style>

        <Style x:Key="TransactionPrimaryButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="112"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
        </Style>

        <Style x:Key="TransactionSecondaryButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
        </Style>

        <Style x:Key="FilterChipButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="Background" Value="{DynamicResource SidebarUserBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template" Value="{StaticResource RoundedButtonTemplate}"/>
        </Style>

        <Style x:Key="RowActionButton" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Background" Value="{DynamicResource MutedCardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="11">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SidebarHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel Background="Transparent">
        <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1"
                    Command="{Binding NewCommand}"
                    Style="{StaticResource TransactionPrimaryButton}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Plus" Width="17" Height="17" Margin="0,0,7,0"/>
                    <TextBlock Text="{DynamicResource TransactionAddText}"/>
                </StackPanel>
            </Button>
        </Grid>

        <Border Margin="0,0,0,14">
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource TransactionCard}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEditorOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel>
                <DockPanel Margin="0,0,0,13">
                    <Button DockPanel.Dock="Right"
                            Command="{Binding CancelCommand}"
                            Content="{DynamicResource CloseText}"
                            Style="{StaticResource TransactionSecondaryButton}"/>
                    <TextBlock Text="{Binding EditorTitle}"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontWeight="SemiBold"
                               FontSize="17"
                               VerticalAlignment="Center"/>
                </DockPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="13"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="13"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="13"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="13"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="13"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{DynamicResource TransactionDescriptionLabel}" Style="{StaticResource MutedLabel}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{DynamicResource AmountLabel}" Style="{StaticResource MutedLabel}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="{DynamicResource TypeLabel}" Style="{StaticResource MutedLabel}" Margin="0,0,0,6"/>
                        <ComboBox ItemsSource="{Binding TypeOptions}" SelectedValuePath="Value" SelectedValue="{Binding Type}" DisplayMemberPath="DisplayName"/>
                    </StackPanel>

                    <StackPanel Grid.Column="6">
                        <TextBlock Text="{DynamicResource CategoryLabel}" Style="{StaticResource MutedLabel}" Margin="0,0,0,6"/>
                        <ComboBox ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding SelectedCategory}"
                                  DisplayMemberPath="EffectiveDisplayName"/>
                        <Button Command="{Binding OpenQuickCategoryCommand}"
                                Style="{StaticResource TransactionSecondaryButton}"
                                Height="30"
                                Padding="10,0"
                                Margin="0,6,0,0"
                                HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="PlusCircleOutline" Width="14" Height="14" Margin="0,0,5,0"/>
                                <TextBlock Text="{DynamicResource AddCategoryText}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="8">
                        <TextBlock Text="{DynamicResource DateLabel}" Style="{StaticResource MutedLabel}" Margin="0,0,0,6"/>
                        <DatePicker SelectedDate="{Binding Date}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="10" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <Button Content="{DynamicResource DeleteText}"
                                Command="{Binding DeleteCommand}"
                                Margin="0,0,12,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource DangerButton}">
                                    <Setter Property="Height" Value="40"/>
                                    <Setter Property="Padding" Value="14,0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTransaction}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="{DynamicResource SaveText}"
                                Command="{Binding SaveCommand}"
                                Style="{StaticResource TransactionPrimaryButton}"/>
                    </StackPanel>
                </Grid>

                <Border Margin="0,14,0,0"
                        Padding="14"
                        CornerRadius="14"
                        Background="{DynamicResource MutedCardBrush}"
                        BorderBrush="{DynamicResource BorderBrushSoft}"
                        BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsQuickCategoryOpen}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="13"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="13"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="13"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{DynamicResource NewCategoryNameLabel}" Style="{StaticResource MutedLabel}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding NewCategoryName, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{DynamicResource ColorLabel}" Style="{StaticResource MutedLabel}" Margin="0,0,0,6"/>
                                                        <ListBox ItemsSource="{Binding ColorPaletteOptions}"
                                     SelectedValuePath="Value"
                                     SelectedValue="{Binding SelectedNewCategoryPaletteColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ColorPaletteListBox}"
                                     ItemContainerStyle="{StaticResource ColorPaletteItem}"
                                     ItemTemplate="{StaticResource ColorPaletteItemTemplate}"/>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="38"
                                        Height="38"
                                        CornerRadius="12"
                                        Background="{Binding NewCategoryColorPreviewBrush}"
                                        BorderBrush="{DynamicResource BorderBrushSoft}"
                                        BorderThickness="1"/>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{Binding NewCategoryColor}"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="11"/>
                                    <Grid Margin="0,4,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="24"/>
                                            <RowDefinition Height="24"/>
                                            <RowDefinition Height="24"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="32"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="R" Foreground="#EF4444" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Minimum="0" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding NewCategoryColorRed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding NewCategoryColorRed, StringFormat={}{0:F0}}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                                        <TextBlock Grid.Row="1" Text="G" Foreground="#10B981" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                                        <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding NewCategoryColorGreen, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding NewCategoryColorGreen, StringFormat={}{0:F0}}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                                        <TextBlock Grid.Row="2" Text="B" Foreground="#2563EB" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                                        <Slider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding NewCategoryColorBlue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding NewCategoryColorBlue, StringFormat={}{0:F0}}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="{DynamicResource IconLabel}" Style="{StaticResource MutedLabel}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding NewCategoryIcon, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Bottom">
                            <Button Content="{DynamicResource CancelText}"
                                    Command="{Binding CancelQuickCategoryCommand}"
                                    Style="{StaticResource TransactionSecondaryButton}"
                                    Margin="0,0,8,0"/>
                            <Button Content="{DynamicResource SaveCategoryText}"
                                    Command="{Binding CreateQuickCategoryCommand}"
                                    Style="{StaticResource TransactionPrimaryButton}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource TransactionCard}" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Padding="39,0,12,0"
                             MinHeight="38"
                             VerticalContentAlignment="Center"/>
                    <materialDesign:PackIcon Kind="Magnify"
                                             Width="18"
                                             Height="18"
                                             Foreground="{DynamicResource SecondaryTextBrush}"
                                             Margin="12,0,0,0"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Center"/>
                </Grid>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0">
                    <Button Content="{DynamicResource AllFilterText}" Command="{Binding SelectFilterCommand}" CommandParameter="All">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FilterChipButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAllFilterSelected}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="{DynamicResource IncomeTypeText}" Command="{Binding SelectFilterCommand}" CommandParameter="Income">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FilterChipButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsIncomeFilterSelected}" Value="True">
                                        <Setter Property="Background" Value="#10B981"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="{DynamicResource ExpenseTypeText}" Command="{Binding SelectFilterCommand}" CommandParameter="Expense">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FilterChipButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsExpenseFilterSelected}" Value="True">
                                        <Setter Property="Background" Value="#EF4444"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Style="{StaticResource TransactionCard}" Padding="0">
            <StackPanel>
                <Grid Background="{DynamicResource MutedCardBrush}" Height="42">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="125"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="88"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{DynamicResource DateLabel}" Grid.Column="0" Style="{StaticResource MutedLabel}" FontSize="11" Margin="14,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource TransactionNameColumn}" Grid.Column="1" Style="{StaticResource MutedLabel}" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource CategoryLabel}" Grid.Column="2" Style="{StaticResource MutedLabel}" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource TypeLabel}" Grid.Column="3" Style="{StaticResource MutedLabel}" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource AmountLabel}" Grid.Column="4" Style="{StaticResource MutedLabel}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource ActionsColumn}" Grid.Column="5" Style="{StaticResource MutedLabel}" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>

                <Grid>
                    <ItemsControl ItemsSource="{Binding TransactionItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderBrushSoft}"
                                        BorderThickness="0,0,0,1"
                                        Padding="0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="125"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="170"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="170"/>
                                            <ColumnDefinition Width="88"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding DateText}"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   FontSize="11"
                                                   Margin="14,0"
                                                   VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Width="27" Height="27" CornerRadius="14" Background="{Binding IconBackgroundBrush}" Margin="0,0,9,0">
                                                <TextBlock Text="{Binding IconText}"
                                                           Foreground="{Binding AmountBrush}"
                                                           FontWeight="Bold"
                                                           FontSize="15"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding Description}"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <Border Grid.Column="2"
                                                Background="{Binding CategoryBackgroundBrush}"
                                                CornerRadius="9"
                                                Padding="8,4"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding CategoryName}"
                                                       Foreground="{Binding CategoryBrush}"
                                                       FontWeight="SemiBold"
                                                       FontSize="10"/>
                                        </Border>

                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding TypeText}"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding AmountText}"
                                                   Foreground="{Binding AmountBrush}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="5"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <Button Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource RowActionButton}">
                                                <materialDesign:PackIcon Kind="PencilOutline" Width="15" Height="15" Foreground="{DynamicResource PrimaryBrush}"/>
                                            </Button>
                                            <Button Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource RowActionButton}">
                                                <materialDesign:PackIcon Kind="DeleteOutline" Width="15" Height="15" Foreground="{DynamicResource DangerBrush}"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="{DynamicResource NoMatchingTransactionsText}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               Margin="0,26">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasTransactions}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <TextBlock Text="{Binding FilteredCountText}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="11"
                           Margin="14,10,14,12"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>

