<UserControl x:Class="QuanLyTaiChinhCaNhan_Nhom06.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#EEF4FF">
    <UserControl.Resources>
        <DropShadowEffect x:Key="AuthCardShadow" BlurRadius="30" ShadowDepth="8" Opacity="0.18" Color="#2563EB"/>
        <DropShadowEffect x:Key="AuthButtonShadow" BlurRadius="18" ShadowDepth="6" Opacity="0.28" Color="#2563EB"/>

        <Style x:Key="AuthLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#243B61"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="AuthInputBox" TargetType="Border">
            <Setter Property="Height" Value="52"/>
            <Setter Property="CornerRadius" Value="13"/>
            <Setter Property="Background" Value="#F8FBFF"/>
            <Setter Property="BorderBrush" Value="#C8DAF6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <Style x:Key="AuthTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#10213F"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#2563EB"/>
        </Style>

        <Style x:Key="AuthPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#10213F"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#2563EB"/>
        </Style>

        <Style x:Key="AuthPlaceholder" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8090B0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="Margin" Value="0,0,0,1"/>
        </Style>

        <Style x:Key="AuthPrimaryButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryGradient}"/>
            <Setter Property="Effect" Value="{StaticResource AuthButtonShadow}"/>
        </Style>
    </UserControl.Resources>

    <Grid ClipToBounds="True">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#DCEBFF" Offset="0"/>
                <GradientStop Color="#EAF5FF" Offset="0.42"/>
                <GradientStop Color="#C9F7FA" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Ellipse Width="420" Height="420" Fill="#BFD7FF" Opacity="0.35" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-180,0,0,-120"/>
        <Ellipse Width="300" Height="300" Stroke="White" StrokeThickness="2" Opacity="0.42" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-130,-80,0"/>

        <Border Width="430"
                Padding="34,28"
                CornerRadius="24"
                Background="#F3FFFFFF"
                BorderBrush="#D8E8FF"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Effect="{StaticResource AuthCardShadow}">
            <StackPanel>
                <Border Width="108" Height="108" CornerRadius="54" Background="#45FFFFFF" HorizontalAlignment="Center" Margin="0,0,0,8">
                    <Border Width="82" Height="82" CornerRadius="18" Background="{StaticResource PrimaryGradient}" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="CreditCard" Width="42" Height="42" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Border>

                <TextBlock Text="{DynamicResource LoginWelcomeText}"
                           FontSize="30"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#2563EB" Offset="0"/>
                            <GradientStop Color="#06B6D4" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>

                <TextBlock Text="{DynamicResource LoginSubtitleText}"
                           FontSize="14"
                           Foreground="#7282A2"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,28"/>

                <TextBlock Text="{DynamicResource UsernameLabel}" Style="{StaticResource AuthLabel}"/>
                <Border Style="{StaticResource AuthInputBox}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="Account" Width="20" Height="20" Foreground="#7185AA" VerticalAlignment="Center"/>
                        <Grid Grid.Column="1">
                            <TextBox x:Name="UsernameInput"
                                     Style="{StaticResource AuthTextBox}"
                                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="{DynamicResource UsernamePlaceholderText}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource AuthPlaceholder}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=UsernameInput}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </Border>

                <TextBlock Text="{DynamicResource PasswordLabel}" Style="{StaticResource AuthLabel}"/>
                <Border Style="{StaticResource AuthInputBox}" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34"/>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="34"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="Lock" Width="19" Height="19" Foreground="#7185AA" VerticalAlignment="Center"/>
                        <Grid Grid.Column="1">
                            <PasswordBox x:Name="PasswordInput"
                                         Style="{StaticResource AuthPasswordBox}"
                                         PasswordChanged="PasswordBox_PasswordChanged"/>
                            <TextBox x:Name="VisiblePasswordInput"
                                     Style="{StaticResource AuthTextBox}"
                                     Visibility="Collapsed"
                                     TextChanged="VisiblePasswordInput_TextChanged"/>
                            <TextBlock x:Name="PasswordPlaceholder" Text="{DynamicResource PasswordPlaceholderText}" Style="{StaticResource AuthPlaceholder}"/>
                        </Grid>
                        <materialDesign:PackIcon x:Name="PasswordVisibilityIcon"
                                                 Grid.Column="2"
                                                 Kind="Eye"
                                                 Width="21"
                                                 Height="21"
                                                 Foreground="#7185AA"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Center"
                                                 Cursor="Hand"
                                                 Opacity="0.72"
                                                 MouseLeftButtonDown="TogglePasswordVisibility_Click"/>
                    </Grid>
                </Border>

                <Grid Margin="0,0,0,18">
                    <CheckBox Content="{DynamicResource RememberLoginText}" Foreground="#6B7894" FontSize="13" IsChecked="True"/>
                    <TextBlock Text="{DynamicResource ForgotPasswordText}" Foreground="#2563EB" FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <TextBlock Text="{Binding Message}"
                           Foreground="#EF4444"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"
                           HorizontalAlignment="Center"/>

                <Button Content="{DynamicResource LoginButtonText}"
                        Style="{StaticResource AuthPrimaryButton}"
                        Command="{Binding LoginCommand}"
                        Margin="0,0,0,22"/>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Border Height="1" Background="#D8E4F7" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Width="26" Height="26" CornerRadius="13" Background="#F8FBFF" BorderBrush="#D8E4F7" BorderThickness="1" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="ShieldCheck" Width="15" Height="15" Foreground="#9BB0CF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Grid.Column="2" Height="1" Background="#D8E4F7" VerticalAlignment="Center"/>
                </Grid>

                <TextBlock HorizontalAlignment="Center" FontSize="14" Foreground="#6B7894">
                    <Run Text="{DynamicResource NoAccountText}"/>
                    <Hyperlink Command="{Binding ShowRegisterCommand}" Foreground="#2563EB" FontWeight="Bold" TextDecorations="{x:Null}">
                        <Run Text="{DynamicResource RegisterNowText}"/>
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>