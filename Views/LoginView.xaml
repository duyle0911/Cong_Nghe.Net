<UserControl x:Class="QuanLyTaiChinhCaNhan_Nhom06.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#EEF4FF">

    <Grid ClipToBounds="True">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#EEF4FF" Offset="0"/>
                <GradientStop Color="#E0EAFF" Offset="0.45"/>
                <GradientStop Color="#F5F3FF" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Ellipse Width="360" Height="360" Fill="#C4B5FD" Opacity="0.35"
                 HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-80,70,0,0">
            <Ellipse.Effect>
                <BlurEffect Radius="90"/>
            </Ellipse.Effect>
        </Ellipse>

        <Ellipse Width="360" Height="360" Fill="#67E8F9" Opacity="0.28"
                 HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-80,70">
            <Ellipse.Effect>
                <BlurEffect Radius="90"/>
            </Ellipse.Effect>
        </Ellipse>

        <Border Width="430"
                Padding="32"
                CornerRadius="26"
                Background="#FDFEFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Effect="{StaticResource CardShadow}">

            <StackPanel>
                <Border Width="80" Height="80" CornerRadius="18"
                        Background="{StaticResource PrimaryGradient}"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16">
                    <TextBlock Text="💳" FontSize="38" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="Chào mừng trở lại"
                           FontSize="30"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#06B6D4" Offset="0"/>
                            <GradientStop Color="#10B981" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>

                <TextBlock Text="Đăng nhập để tiếp tục quản lý tài chính"
                           FontSize="14"
                           Foreground="#64748B"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <TextBlock Text="Tên đăng nhập"
                           Foreground="#334155"
                           FontWeight="Medium"
                           FontSize="14"
                           Margin="0,0,0,8"/>

                <Border Height="50"
                        CornerRadius="14"
                        Background="#F8FAFC"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        Margin="0,0,0,22">
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="👤" Foreground="#64748B" FontSize="17" VerticalAlignment="Center"/>

                        <TextBox Grid.Column="1"
                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#0F172A"
                                 FontSize="14"
                                 VerticalContentAlignment="Center"
                                 CaretBrush="#22D3EE"/>
                    </Grid>
                </Border>

                <TextBlock Text="Mật khẩu"
                           Foreground="#334155"
                           FontWeight="Medium"
                           FontSize="14"
                           Margin="0,0,0,8"/>

                <Border Height="50"
                        CornerRadius="14"
                        Background="#F8FAFC"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        Margin="0,0,0,18">
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="34"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="🔒" Foreground="#64748B" FontSize="17" VerticalAlignment="Center"/>

                        <PasswordBox x:Name="PasswordInput"
                                     Grid.Column="1"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#0F172A"
                                     FontSize="14"
                                     VerticalContentAlignment="Center"
                                     PasswordChanged="PasswordBox_PasswordChanged"/>

                        <TextBox x:Name="VisiblePasswordInput"
                                 Grid.Column="1"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#0F172A"
                                 FontSize="14"
                                 VerticalContentAlignment="Center"
                                 Visibility="Collapsed"
                                 TextChanged="VisiblePasswordInput_TextChanged"/>

                        <TextBlock x:Name="PasswordVisibilityIcon"
                                   Grid.Column="2"
                                   Text="👁"
                                   Foreground="#64748B"
                                   FontSize="15"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Cursor="Hand"
                                   MouseLeftButtonDown="TogglePasswordVisibility_Click"/>
                    </Grid>
                </Border>

                <TextBlock Text="{Binding Message}"
                           Foreground="#EF4444"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"
                           HorizontalAlignment="Center"/>

                <Button Content="Đăng nhập"
                        Style="{StaticResource RoundedButton}"
                        Command="{Binding LoginCommand}"
                        Margin="0,0,0,24"/>

                <Grid Margin="0,0,0,22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Border Height="1" Background="#CBD5E1" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="HOẶC" Foreground="#94A3B8" FontSize="13" Margin="14,0"/>
                    <Border Grid.Column="2" Height="1" Background="#CBD5E1" VerticalAlignment="Center"/>
                </Grid>

                <TextBlock HorizontalAlignment="Center" FontSize="14" Foreground="#64748B">
                    <Run Text="Chưa có tài khoản? "/>
                    <Hyperlink Command="{Binding ShowRegisterCommand}"
                               Foreground="#06B6D4"
                               FontWeight="SemiBold"
                               TextDecorations="{x:Null}">
                        Đăng ký ngay
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
