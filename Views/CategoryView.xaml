<UserControl x:Class="QuanLyTaiChinhCaNhan_Nhom06.Views.CategoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <UserControl.Resources>
        <Style x:Key="CategoryCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,14,14"/>
        </Style>

        <Style x:Key="CompactActionButton" TargetType="Button">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Background" Value="{DynamicResource MutedCardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#E0F2FE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CompactSecondaryButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
        </Style>

        <Style x:Key="CompactPrimaryButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
        </Style>

        <Style x:Key="CompactDangerButton" TargetType="Button" BasedOn="{StaticResource DangerButton}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
        </Style>
    </UserControl.Resources>

    <StackPanel Background="Transparent">
        <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Command="{Binding NewCommand}"
                    Style="{StaticResource CompactPrimaryButton}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Margin="0,0,8,0"/>
                    <TextBlock Text="{DynamicResource CategoryAddText}"/>
                </StackPanel>
            </Button>
        </Grid>

        <Border Padding="20"
                Margin="0,0,0,18">
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource ShellCard}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEditorOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <StackPanel>
                <DockPanel Margin="0,0,0,16">
                    <Button DockPanel.Dock="Right"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource CompactActionButton}">
                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18" Foreground="{StaticResource SecondaryTextBrush}"/>
                    </Button>
                    <TextBlock Text="{Binding EditorTitle}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               VerticalAlignment="Center"/>
                </DockPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{DynamicResource CategoryNameLabel}" Style="{StaticResource MutedLabel}" Margin="0,0,0,7"/>
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{DynamicResource TypeLabel}" Style="{StaticResource MutedLabel}" Margin="0,0,0,7"/>
                        <ComboBox ItemsSource="{Binding TypeOptions}" SelectedValuePath="Value" SelectedValue="{Binding Type}" DisplayMemberPath="DisplayName"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="{DynamicResource ColorLabel}" Style="{StaticResource MutedLabel}" Margin="0,0,0,7"/>
                                                <ListBox ItemsSource="{Binding ColorPaletteOptions}"
                                 SelectedValuePath="Value"
                                 SelectedValue="{Binding SelectedPaletteColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ColorPaletteListBox}"
                                 ItemContainerStyle="{StaticResource ColorPaletteItem}"
                                 ItemTemplate="{StaticResource ColorPaletteItemTemplate}"/>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="38"
                                    Height="38"
                                    CornerRadius="12"
                                    Background="{Binding ColorPreviewBrush}"
                                    BorderBrush="{DynamicResource BorderBrushSoft}"
                                    BorderThickness="1"/>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{Binding Color}"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="11"/>
                                <Grid Margin="0,4,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="24"/>
                                        <RowDefinition Height="24"/>
                                        <RowDefinition Height="24"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="32"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="R" Foreground="#EF4444" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="0" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding ColorRed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding ColorRed, StringFormat={}{0:F0}}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="1" Text="G" Foreground="#10B981" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                                    <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding ColorGreen, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding ColorGreen, StringFormat={}{0:F0}}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="2" Text="B" Foreground="#2563EB" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                                    <Slider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding ColorBlue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding ColorBlue, StringFormat={}{0:F0}}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="6">
                        <TextBlock Text="{DynamicResource IconLabel}" Style="{StaticResource MutedLabel}" Margin="0,0,0,7"/>
                        <TextBox Text="{Binding Icon, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,16,0,0">
                    <Button Content="{DynamicResource DeleteCategoryText}"
                            Command="{Binding DeleteCommand}"
                            Margin="0,0,12,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource CompactDangerButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedCategory}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="{DynamicResource CancelText}"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource CompactSecondaryButton}"
                            Margin="0,0,12,0"/>
                    <Button Content="{DynamicResource SaveCategoryText}"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource CompactPrimaryButton}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <ItemsControl ItemsSource="{Binding CategoryOverviews}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="3"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CategoryCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="42"
                                        Height="42"
                                        CornerRadius="12"
                                        Background="{Binding AccentBrush}">
                                    <materialDesign:PackIcon Kind="{Binding IconKind}"
                                                             Foreground="White"
                                                             Width="22"
                                                             Height="22"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"/>
                                </Border>

                                <Border Grid.Column="1"
                                        Background="{Binding SoftAccentBrush}"
                                        CornerRadius="10"
                                        Padding="9,4"
                                        Margin="10,0,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TypeLabel}"
                                               Foreground="{Binding AccentBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="11"/>
                                </Border>

                                <Button Grid.Column="2"
                                        Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding Category}"
                                        Style="{StaticResource CompactActionButton}">
                                    <materialDesign:PackIcon Kind="PencilOutline"
                                                             Width="17"
                                                             Height="17"
                                                             Foreground="{StaticResource SecondaryTextBrush}"/>
                                </Button>
                            </Grid>

                            <TextBlock Grid.Row="1"
                                       Text="{Binding Name}"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Margin="0,14,0,11"/>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="{Binding TotalLabel}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding TotalAmountText}" Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold" FontSize="12"/>

                                <TextBlock Grid.Row="1" Text="{DynamicResource CategoryTransactionsText}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" Margin="0,7,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TransactionCount}" Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold" FontSize="12" Margin="0,7,0,0"/>

                                <TextBlock Grid.Row="2" Text="{DynamicResource BudgetText}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" Margin="0,7,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding BudgetAmountText}" Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold" FontSize="12" Margin="0,7,0,0"/>
                            </Grid>

                            <StackPanel Grid.Row="3" Margin="0,13,0,0">
                                <Grid Margin="0,0,0,5">
                                    <TextBlock Text="{DynamicResource ProgressText}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding ProgressText}" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Right"/>
                                </Grid>
                                <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}"
                                             Maximum="100"
                                             Height="6"
                                             Foreground="{Binding AccentBrush}"
                                             Background="#E2E8F0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Style="{StaticResource ShellCard}"
                Padding="20"
                Margin="0,4,0,0">
            <StackPanel>
                <TextBlock Text="{DynamicResource CategoryDetailsTitle}"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           FontWeight="SemiBold"
                           FontSize="17"
                           Margin="0,0,0,14"/>

                <Grid>
                    <DataGrid ItemsSource="{Binding CategoryOverviews}"
                              SelectedItem="{Binding SelectedOverview}"
                              IsReadOnly="True"
                              MinHeight="320">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="{DynamicResource CategoryLabel}" Width="2*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Width="28" Height="28" CornerRadius="9" Background="{Binding AccentBrush}">
                                                <materialDesign:PackIcon Kind="{Binding IconKind}"
                                                                         Foreground="White"
                                                                         Width="15"
                                                                         Height="15"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       Margin="10,0,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="{DynamicResource TypeLabel}" Binding="{Binding TypeLabel}" Width="100"/>
                            <DataGridTextColumn Header="{DynamicResource TotalAmountColumn}" Binding="{Binding TotalAmountText}" Width="140"/>
                            <DataGridTextColumn Header="{DynamicResource CategoryTransactionsText}" Binding="{Binding TransactionCount}" Width="90"/>
                            <DataGridTextColumn Header="{DynamicResource BudgetText}" Binding="{Binding BudgetAmountText}" Width="140"/>
                            <DataGridTextColumn Header="{DynamicResource RemainingColumn}" Binding="{Binding RemainingAmountText}" Width="130"/>

                            <DataGridTemplateColumn Header="{DynamicResource UsedPercentColumn}" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="44"/>
                                            </Grid.ColumnDefinitions>
                                            <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}"
                                                         Maximum="100"
                                                         Height="6"
                                                         Foreground="{Binding AccentBrush}"
                                                         Background="#E2E8F0"
                                                         VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding ProgressText}"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="{DynamicResource StatusColumn}" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding StatusBackground}"
                                                CornerRadius="10"
                                                Padding="9,4"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding StatusText}"
                                                       Foreground="{Binding StatusForeground}"
                                                       FontWeight="SemiBold"
                                                       FontSize="11"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Text="{DynamicResource NoCategoriesText}"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasCategories}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>

