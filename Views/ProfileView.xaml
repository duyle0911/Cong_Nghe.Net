<UserControl x:Class="QuanLyTaiChinhCaNhan_Nhom06.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="ProfileCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        <Style x:Key="ProfileActionButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
        </Style>
    </UserControl.Resources>

    <StackPanel Background="Transparent">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource ProfileCard}">
                <StackPanel>
                    <Border Width="72" Height="72" CornerRadius="36" Background="{DynamicResource PrimaryGradient}" HorizontalAlignment="Center" Margin="0,0,0,11" ClipToBounds="True">
                        <Grid>
                            <Image Source="{Binding Avatar}"
                                   Stretch="UniformToFill"
                                   Visibility="{Binding HasAvatar, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <TextBlock Text="{Binding Initials}" Foreground="White" FontWeight="Bold" FontSize="23" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasAvatar}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                    <TextBlock Text="{Binding FullName}" Foreground="{DynamicResource PrimaryTextBrush}" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Username}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button Content="Chọn ảnh"
                                Command="{Binding ChooseAvatarCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Height="36"
                                Padding="14,0"
                                FontSize="11"
                                Margin="0,0,12,0"/>
                        <Button Content="Gỡ ảnh"
                                Command="{Binding ClearAvatarCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Height="36"
                                Padding="14,0"
                                FontSize="11"/>
                    </StackPanel>
                    <Border Background="{DynamicResource SidebarHoverBrush}" CornerRadius="10" Padding="10,6" Margin="0,16,0,0">
                        <TextBlock Text="{Binding MemberSinceText}" Foreground="{DynamicResource PrimaryBrush}" FontSize="11" HorizontalAlignment="Center"/>
                    </Border>
                    <Border Background="{DynamicResource SidebarUserBrush}" CornerRadius="10" Padding="10,6" Margin="0,8,0,0">
                        <TextBlock Text="Tài khoản MoneyFlow" Foreground="{DynamicResource SecondaryBrush}" FontSize="11" HorizontalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Cập nhật ảnh đại diện, thông tin cá nhân và tùy chỉnh giao diện ở phần bên phải."
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               FontSize="11"
                               Margin="0,18,0,0"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="2">
                <Border Style="{StaticResource ProfileCard}" Margin="0,0,0,12">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <materialDesign:PackIcon Kind="AccountOutline" Foreground="{DynamicResource PrimaryBrush}" Width="19" Height="19" Margin="0,0,8,0"/>
                            <TextBlock Text="Thông tin cá nhân" Foreground="{DynamicResource PrimaryTextBrush}" FontWeight="SemiBold" FontSize="15"/>
                        </DockPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Họ và tên" Style="{StaticResource MutedLabel}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Email" Style="{StaticResource MutedLabel}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                        <Button Content="Lưu thay đổi" Command="{Binding SaveProfileCommand}" Style="{StaticResource ProfileActionButton}" HorizontalAlignment="Right" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ProfileCard}" Margin="0,0,0,12">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <materialDesign:PackIcon Kind="ShieldLockOutline" Foreground="{DynamicResource PrimaryBrush}" Width="19" Height="19" Margin="0,0,8,0"/>
                            <TextBlock Text="Bảo mật" Foreground="{DynamicResource PrimaryTextBrush}" FontWeight="SemiBold" FontSize="15"/>
                        </DockPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Mật khẩu hiện tại" Style="{StaticResource MutedLabel}" Margin="0,0,0,6"/>
                                <PasswordBox x:Name="CurrentPasswordBox" PasswordChanged="CurrentPasswordBox_PasswordChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Mật khẩu mới" Style="{StaticResource MutedLabel}" Margin="0,0,0,6"/>
                                <PasswordBox x:Name="NewPasswordBox" PasswordChanged="NewPasswordBox_PasswordChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Xác nhận mật khẩu" Style="{StaticResource MutedLabel}" Margin="0,0,0,6"/>
                                <PasswordBox x:Name="ConfirmPasswordBox" PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>
                            </StackPanel>
                        </Grid>
                        <Button Content="Đổi mật khẩu" Command="{Binding ChangePasswordCommand}" Style="{StaticResource AccentButton}" Height="38" Padding="14,0" HorizontalAlignment="Right" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ProfileCard}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <materialDesign:PackIcon Kind="PaletteOutline" Foreground="{DynamicResource PrimaryBrush}" Width="19" Height="19" Margin="0,0,8,0"/>
                            <TextBlock Text="Giao diện và ngôn ngữ" Foreground="{DynamicResource PrimaryTextBrush}" FontWeight="SemiBold" FontSize="15"/>
                        </DockPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Chế độ hiển thị" Style="{StaticResource MutedLabel}" Margin="0,0,0,7"/>
                                <CheckBox IsChecked="{Binding IsDarkMode}" Content="Bật giao diện tối" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Màu chủ đạo" Style="{StaticResource MutedLabel}" Margin="0,0,0,6"/>
                                <ComboBox ItemsSource="{Binding AccentColors}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Name"
                                          SelectedValue="{Binding SelectedAccentColor}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Ngôn ngữ" Style="{StaticResource MutedLabel}" Margin="0,0,0,6"/>
                                <ComboBox ItemsSource="{Binding Languages}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Code"
                                          SelectedValue="{Binding SelectedLanguageCode}"/>
                            </StackPanel>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding AccentColors}" Margin="0,12,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                        <Ellipse Width="16" Height="16" Fill="{Binding PrimaryColor}"/>
                                        <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <DockPanel Margin="0,12,0,0">
                            <Button DockPanel.Dock="Right" Content="Lưu tùy chỉnh" Command="{Binding SaveAppearanceCommand}" Style="{StaticResource ProfileActionButton}"/>
                            <TextBlock Text="Ngôn ngữ được lưu cho lần mở ứng dụng tiếp theo; định dạng ngày và số được áp dụng ngay."
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontSize="11"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding Message}" Foreground="{DynamicResource PrimaryBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,10,0,0"/>
            </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>
