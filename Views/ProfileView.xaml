<UserControl x:Class="QuanLyTaiChinhCaNhan_Nhom06.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="ProfileCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        <Style x:Key="ProfileActionButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
        </Style>
    </UserControl.Resources>

    <StackPanel Background="Transparent">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource ProfileCard}">
                <StackPanel>
                    <Border Width="72" Height="72" CornerRadius="36" Background="{DynamicResource PrimaryGradient}" HorizontalAlignment="Center" Margin="0,0,0,11" ClipToBounds="True">
                        <Grid>
                            <Image Source="{Binding Avatar}"
                                   Stretch="UniformToFill"
                                   Visibility="{Binding HasAvatar, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <TextBlock Text="{Binding Initials}" Foreground="White" FontWeight="Bold" FontSize="23" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasAvatar}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                    <TextBlock Text="{Binding FullName}" Foreground="{DynamicResource PrimaryTextBrush}" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Username}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button Content="{DynamicResource ProfileChooseAvatarText}"
                                Command="{Binding ChooseAvatarCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Height="36"
                                Padding="14,0"
                                FontSize="11"
                                Margin="0,0,12,0"/>
                        <Button Content="{DynamicResource ProfileClearAvatarText}"
                                Command="{Binding ClearAvatarCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Height="36"
                                Padding="14,0"
                                FontSize="11"/>
                    </StackPanel>
                    <Border Background="{DynamicResource SidebarHoverBrush}" CornerRadius="10" Padding="10,6" Margin="0,16,0,0">
                        <TextBlock Text="{Binding MemberSinceText}" Foreground="{DynamicResource PrimaryBrush}" FontSize="11" HorizontalAlignment="Center"/>
                    </Border>
                    <Border Background="{DynamicResource SidebarUserBrush}" CornerRadius="10" Padding="10,6" Margin="0,8,0,0">
                        <TextBlock Text="{DynamicResource ProfileAccountBadgeText}" Foreground="{DynamicResource SecondaryBrush}" FontSize="11" HorizontalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{DynamicResource ProfileIntroText}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               FontSize="11"
                               Margin="0,18,0,0"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="2">
                <Border Style="{StaticResource ProfileCard}" Margin="0,0,0,12">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <materialDesign:PackIcon Kind="AccountOutline" Foreground="{DynamicResource PrimaryBrush}" Width="19" Height="19" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource ProfileInfoTitle}" Foreground="{DynamicResource PrimaryTextBrush}" FontWeight="SemiBold" FontSize="15"/>
                        </DockPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource ProfileFullNameLabel}" Style="{StaticResource MutedLabel}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{DynamicResource ProfileEmailLabel}" Style="{StaticResource MutedLabel}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                        <Button Content="{DynamicResource ProfileSaveChangesText}" Command="{Binding SaveProfileCommand}" Style="{StaticResource ProfileActionButton}" HorizontalAlignment="Right" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ProfileCard}" Margin="0,0,0,12">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <materialDesign:PackIcon Kind="ShieldLockOutline" Foreground="{DynamicResource PrimaryBrush}" Width="19" Height="19" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource ProfileSecurityTitle}" Foreground="{DynamicResource PrimaryTextBrush}" FontWeight="SemiBold" FontSize="15"/>
                        </DockPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource ProfileCurrentPasswordLabel}" Style="{StaticResource MutedLabel}" Margin="0,0,0,6"/>
                                <PasswordBox x:Name="CurrentPasswordBox" PasswordChanged="CurrentPasswordBox_PasswordChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{DynamicResource ProfileNewPasswordLabel}" Style="{StaticResource MutedLabel}" Margin="0,0,0,6"/>
                                <PasswordBox x:Name="NewPasswordBox" PasswordChanged="NewPasswordBox_PasswordChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="{DynamicResource ProfileConfirmPasswordLabel}" Style="{StaticResource MutedLabel}" Margin="0,0,0,6"/>
                                <PasswordBox x:Name="ConfirmPasswordBox" PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>
                            </StackPanel>
                        </Grid>
                        <Button Content="{DynamicResource ProfileChangePasswordText}" Command="{Binding ChangePasswordCommand}" Style="{StaticResource AccentButton}" Height="38" Padding="14,0" HorizontalAlignment="Right" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ProfileCard}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <materialDesign:PackIcon Kind="PaletteOutline" Foreground="{DynamicResource PrimaryBrush}" Width="19" Height="19" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource ProfileAppearanceTitle}" Foreground="{DynamicResource PrimaryTextBrush}" FontWeight="SemiBold" FontSize="15"/>
                        </DockPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource ProfileDisplayModeLabel}" Style="{StaticResource MutedLabel}" Margin="0,0,0,7"/>
                                <CheckBox IsChecked="{Binding IsDarkMode}" Content="{DynamicResource ProfileDarkModeText}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13"/>
                                <TextBlock Text="{DynamicResource ProfileBackgroundThemeLabel}" Style="{StaticResource MutedLabel}" Margin="0,14,0,7"/>
                                <ListBox ItemsSource="{Binding BackgroundThemes}"
                                         SelectedValuePath="Name"
                                         SelectedValue="{Binding SelectedBackgroundTheme, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Padding="0"
                                         MaxHeight="150"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,0,8,8"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="Root" CornerRadius="14" Padding="2" BorderThickness="2" BorderBrush="Transparent" Background="Transparent">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Root" Property="BorderBrush" Value="#CBD5E1"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="12" Padding="9,5" BorderBrush="{Binding PrimaryColor}" BorderThickness="1">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="{Binding PrimaryColor}" Offset="0"/>
                                                        <GradientStop Color="{Binding SecondaryColor}" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock Text="{Binding DisplayName}" Foreground="White" FontWeight="SemiBold" FontSize="11"/>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{DynamicResource ProfileAccentColorLabel}" Style="{StaticResource MutedLabel}" Margin="0,0,0,6"/>
                                <ComboBox ItemsSource="{Binding AccentColors}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Name"
                                          SelectedValue="{Binding SelectedAccentColor}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="{DynamicResource ProfileLanguageLabel}" Style="{StaticResource MutedLabel}" Margin="0,0,0,6"/>
                                                                <ComboBox ItemsSource="{Binding Languages}"
                                          SelectedValuePath="Code"
                                          SelectedValue="{Binding SelectedLanguageCode}"
                                          MinHeight="44"
                                          Padding="0">
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        </Style>
                                    </ComboBox.ItemContainerStyle>
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid MinHeight="44" Margin="4,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="42"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="24"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Width="30" Height="20" CornerRadius="2" BorderBrush="#CBD5E1" BorderThickness="1" ClipToBounds="True" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                    <Viewbox Stretch="Fill">
                                                    <Grid>
                                                        <Canvas x:Name="VietnamFlag" Width="54" Height="36" Background="#DA251D">
                                                            <Path Fill="#FFFF00" Data="M27,5 L30.1,15.3 L40.9,15.3 L32.2,21.6 L35.4,31.8 L27,25.5 L18.6,31.8 L21.8,21.6 L13.1,15.3 L23.9,15.3 Z"/>
                                                        </Canvas>
                                                        <Canvas x:Name="EnglishFlag" Width="54" Height="36" Background="#012169" Visibility="Collapsed">
                                                            <Line X1="0" Y1="0" X2="54" Y2="36" Stroke="White" StrokeThickness="9"/>
                                                            <Line X1="54" Y1="0" X2="0" Y2="36" Stroke="White" StrokeThickness="9"/>
                                                            <Line X1="0" Y1="0" X2="54" Y2="36" Stroke="#C8102E" StrokeThickness="4"/>
                                                            <Line X1="54" Y1="0" X2="0" Y2="36" Stroke="#C8102E" StrokeThickness="4"/>
                                                            <Rectangle Width="54" Height="10" Fill="White" Canvas.Top="13"/>
                                                            <Rectangle Width="10" Height="36" Fill="White" Canvas.Left="22"/>
                                                            <Rectangle Width="54" Height="6" Fill="#C8102E" Canvas.Top="15"/>
                                                            <Rectangle Width="6" Height="36" Fill="#C8102E" Canvas.Left="24"/>
                                                        </Canvas>
                                                    </Grid>
                                                    </Viewbox>
                                                </Border>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Subtitle}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,1,0,0"/>
                                                </StackPanel>

                                                <Path x:Name="SelectedCheck" Grid.Column="2" Data="M4,11 L9,16 L18,6" Stroke="{DynamicResource PrimaryBrush}" StrokeThickness="2.2" StrokeEndLineCap="Round" StrokeStartLineCap="Round" StrokeLineJoin="Round" Width="20" Height="20" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                                            </Grid>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding Code}" Value="en-US">
                                                    <Setter TargetName="VietnamFlag" Property="Visibility" Value="Collapsed"/>
                                                    <Setter TargetName="EnglishFlag" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ComboBoxItem}, Path=IsSelected}" Value="True">
                                                    <Setter TargetName="SelectedCheck" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                        <DockPanel Margin="0,12,0,0">
                            <Button DockPanel.Dock="Right" Content="{DynamicResource ProfileSaveAppearanceText}" Command="{Binding SaveAppearanceCommand}" Style="{StaticResource ProfileActionButton}"/>
                            <TextBlock Text="{DynamicResource ProfileLanguageHintText}"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontSize="11"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding Message}" Foreground="{DynamicResource PrimaryBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,10,0,0"/>
            </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>

