<UserControl x:Class="QuanLyTaiChinhCaNhan_Nhom06.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#EEF4FF">
    <UserControl.Resources>
        <DropShadowEffect x:Key="AuthCardShadow" BlurRadius="28" ShadowDepth="8" Opacity="0.18" Color="#2563EB"/>
        <DropShadowEffect x:Key="AuthButtonShadow" BlurRadius="16" ShadowDepth="5" Opacity="0.25" Color="#2563EB"/>

        <Style x:Key="AuthLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#243B61"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Margin" Value="0,0,0,7"/>
        </Style>

        <Style x:Key="AuthInputBox" TargetType="Border">
            <Setter Property="Height" Value="42"/>
            <Setter Property="CornerRadius" Value="11"/>
            <Setter Property="Background" Value="#F8FBFF"/>
            <Setter Property="BorderBrush" Value="#C8DAF6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Margin" Value="0,0,0,13"/>
        </Style>

        <Style x:Key="AuthTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#10213F"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#2563EB"/>
        </Style>

        <Style x:Key="AuthPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#10213F"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#2563EB"/>
        </Style>

        <Style x:Key="AuthPlaceholder" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8090B0"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
        </Style>

        <Style x:Key="AuthPrimaryButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryGradient}"/>
            <Setter Property="Effect" Value="{StaticResource AuthButtonShadow}"/>
        </Style>
    </UserControl.Resources>

    <Grid ClipToBounds="True">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#DCEBFF" Offset="0"/>
                <GradientStop Color="#EAF5FF" Offset="0.42"/>
                <GradientStop Color="#C9F7FA" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Ellipse Width="420" Height="420" Fill="#BFD7FF" Opacity="0.35" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-180,0,0,-120"/>
        <Ellipse Width="300" Height="300" Stroke="White" StrokeThickness="2" Opacity="0.42" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-130,-80,0"/>

        <Border Width="410"
                Padding="32,24"
                CornerRadius="24"
                Background="#F3FFFFFF"
                BorderBrush="#D8E8FF"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Effect="{StaticResource AuthCardShadow}">
            <StackPanel>
                <Border Width="90" Height="90" CornerRadius="45" Background="#45FFFFFF" HorizontalAlignment="Center" Margin="0,0,0,6">
                    <Border Width="68" Height="68" CornerRadius="16" Background="{StaticResource PrimaryGradient}" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="CreditCard" Width="35" Height="35" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Border>

                <TextBlock Text="{DynamicResource RegisterTitleText}"
                           FontSize="30"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,3">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#2563EB" Offset="0"/>
                            <GradientStop Color="#06B6D4" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>

                <TextBlock Text="{DynamicResource RegisterSubtitleText}"
                           FontSize="13.5"
                           Foreground="#7282A2"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>

                <TextBlock Text="{DynamicResource UsernameLabel}" Style="{StaticResource AuthLabel}"/>
                <Border Style="{StaticResource AuthInputBox}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="Account" Width="18" Height="18" Foreground="#7185AA" VerticalAlignment="Center"/>
                        <Grid Grid.Column="1">
                            <TextBox x:Name="UsernameInput" Style="{StaticResource AuthTextBox}" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="{DynamicResource UsernamePlaceholderText}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource AuthPlaceholder}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=UsernameInput}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </Border>

                <TextBlock Text="{DynamicResource FullNameLabel}" Style="{StaticResource AuthLabel}"/>
                <Border Style="{StaticResource AuthInputBox}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="AccountTie" Width="18" Height="18" Foreground="#7185AA" VerticalAlignment="Center"/>
                        <Grid Grid.Column="1">
                            <TextBox x:Name="FullNameInput" Style="{StaticResource AuthTextBox}" Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="{DynamicResource FullNamePlaceholderText}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource AuthPlaceholder}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=FullNameInput}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </Border>

                <TextBlock Text="{DynamicResource ProfileEmailLabel}" Style="{StaticResource AuthLabel}"/>
                <Border Style="{StaticResource AuthInputBox}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="Email" Width="18" Height="18" Foreground="#7185AA" VerticalAlignment="Center"/>
                        <Grid Grid.Column="1">
                            <TextBox x:Name="EmailInput" Style="{StaticResource AuthTextBox}" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="{DynamicResource EmailPlaceholderText}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource AuthPlaceholder}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=EmailInput}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </Border>

                <TextBlock Text="{DynamicResource PasswordLabel}" Style="{StaticResource AuthLabel}"/>
                <Border Style="{StaticResource AuthInputBox}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="Lock" Width="18" Height="18" Foreground="#7185AA" VerticalAlignment="Center"/>
                        <Grid Grid.Column="1">
                            <PasswordBox x:Name="PasswordInput" Style="{StaticResource AuthPasswordBox}" PasswordChanged="PasswordBox_PasswordChanged"/>
                            <TextBox x:Name="VisiblePasswordInput" Style="{StaticResource AuthTextBox}" Visibility="Collapsed" TextChanged="VisiblePasswordInput_TextChanged"/>
                            <TextBlock x:Name="PasswordPlaceholder" Text="{DynamicResource PasswordPlaceholderText}" Style="{StaticResource AuthPlaceholder}"/>
                        </Grid>
                        <Button Grid.Column="2" Panel.ZIndex="2" Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand" Focusable="False" Click="TogglePasswordVisibility_Click">
                            <materialDesign:PackIcon Kind="Eye" Width="18" Height="18" Foreground="#7185AA"/>
                        </Button>
                    </Grid>
                </Border>

                <TextBlock Text="{DynamicResource ConfirmPasswordLabel}" Style="{StaticResource AuthLabel}"/>
                <Border Style="{StaticResource AuthInputBox}" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="Lock" Width="18" Height="18" Foreground="#7185AA" VerticalAlignment="Center"/>
                        <Grid Grid.Column="1">
                            <PasswordBox x:Name="ConfirmPasswordInput" Style="{StaticResource AuthPasswordBox}" PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>
                            <TextBox x:Name="VisibleConfirmPasswordInput" Style="{StaticResource AuthTextBox}" Visibility="Collapsed" TextChanged="VisibleConfirmPasswordInput_TextChanged"/>
                            <TextBlock x:Name="ConfirmPasswordPlaceholder" Text="{DynamicResource ConfirmPasswordPlaceholderText}" Style="{StaticResource AuthPlaceholder}"/>
                        </Grid>
                        <Button Grid.Column="2" Panel.ZIndex="2" Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand" Focusable="False" Click="ToggleConfirmPasswordVisibility_Click">
                            <materialDesign:PackIcon Kind="Eye" Width="18" Height="18" Foreground="#7185AA"/>
                        </Button>
                    </Grid>
                </Border>

                <TextBlock Text="{Binding Message}"
                           Foreground="#EF4444"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"
                           HorizontalAlignment="Center"/>

                <Button Content="{DynamicResource RegisterButtonText}"
                        Style="{StaticResource AuthPrimaryButton}"
                        Command="{Binding RegisterCommand}"
                        Margin="0,0,0,18"/>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Border Height="1" Background="#D8E4F7" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Width="24" Height="24" CornerRadius="12" Background="#F8FBFF" BorderBrush="#D8E4F7" BorderThickness="1" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="ShieldCheck" Width="14" Height="14" Foreground="#9BB0CF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Grid.Column="2" Height="1" Background="#D8E4F7" VerticalAlignment="Center"/>
                </Grid>

                <TextBlock HorizontalAlignment="Center" FontSize="13.5" Foreground="#6B7894">
                    <Run Text="{DynamicResource AlreadyHaveAccountText}"/>
                    <Hyperlink Command="{Binding ShowLoginCommand}" Foreground="#2563EB" FontWeight="Bold" TextDecorations="{x:Null}">
                        <Run Text="{DynamicResource LoginButtonText}"/>
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>