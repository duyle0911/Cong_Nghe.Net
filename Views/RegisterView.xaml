<UserControl x:Class="QuanLyTaiChinhCaNhan_Nhom06.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#EEF4FF">

    <Grid ClipToBounds="True">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#EEF4FF" Offset="0"/>
                <GradientStop Color="#E0EAFF" Offset="0.45"/>
                <GradientStop Color="#F5F3FF" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Ellipse Width="360" Height="360" Fill="#C4B5FD" Opacity="0.35"
                 HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-80,70,0,0">
            <Ellipse.Effect>
                <BlurEffect Radius="90"/>
            </Ellipse.Effect>
        </Ellipse>

        <Ellipse Width="360" Height="360" Fill="#67E8F9" Opacity="0.28"
                 HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-80,70">
            <Ellipse.Effect>
                <BlurEffect Radius="90"/>
            </Ellipse.Effect>
        </Ellipse>

        <Border Width="430"
                Padding="30"
                CornerRadius="26"
                Background="#FDFEFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Effect="{StaticResource CardShadow}">

            <StackPanel>
                <Border Width="72" Height="72" CornerRadius="18"
                        Background="{StaticResource PrimaryGradient}"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,14">
                    <TextBlock Text="💳" FontSize="34" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="Tạo tài khoản"
                           FontSize="30"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#06B6D4" Offset="0"/>
                            <GradientStop Color="#10B981" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>

                <TextBlock Text="Bắt đầu quản lý tài chính của bạn"
                           FontSize="14"
                           Foreground="#64748B"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,22"/>

                <TextBlock Text="Tên đăng nhập" Foreground="#334155" FontWeight="Medium" FontSize="14" Margin="0,0,0,8"/>
                <Border Height="46" CornerRadius="14" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" Margin="0,0,0,14">
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="👤" Foreground="#64748B" FontSize="17" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#0F172A"
                                 FontSize="14"
                                 VerticalContentAlignment="Center"/>
                    </Grid>
                </Border>

                <TextBlock Text="Họ và tên" Foreground="#334155" FontWeight="Medium" FontSize="14" Margin="0,0,0,8"/>
                <Border Height="46" CornerRadius="14" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" Margin="0,0,0,14">
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="♙" Foreground="#64748B" FontSize="17" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#0F172A"
                                 FontSize="14"
                                 VerticalContentAlignment="Center"/>
                    </Grid>
                </Border>

                <TextBlock Text="Email" Foreground="#334155" FontWeight="Medium" FontSize="14" Margin="0,0,0,8"/>
                <Border Height="46" CornerRadius="14" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" Margin="0,0,0,14">
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="✉" Foreground="#64748B" FontSize="17" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#0F172A"
                                 FontSize="14"
                                 VerticalContentAlignment="Center"/>
                    </Grid>
                </Border>

                <TextBlock Text="Mật khẩu" Foreground="#334155" FontWeight="Medium" FontSize="14" Margin="0,0,0,8"/>
                <Border Height="46" CornerRadius="14" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" Margin="0,0,0,14">
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="34"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔒" Foreground="#64748B" FontSize="17" VerticalAlignment="Center"/>
                        <PasswordBox x:Name="PasswordInput"
                                     Grid.Column="1"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#0F172A"
                                     FontSize="14"
                                     VerticalContentAlignment="Center"
                                     PasswordChanged="PasswordBox_PasswordChanged"/>
                        <TextBox x:Name="VisiblePasswordInput"
                                 Grid.Column="1"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#0F172A"
                                 FontSize="14"
                                 VerticalContentAlignment="Center"
                                 Visibility="Collapsed"
                                 TextChanged="VisiblePasswordInput_TextChanged"/>
                        <Button Grid.Column="2"
                                Panel.ZIndex="2"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                Cursor="Hand"
                                Focusable="False"
                                Click="TogglePasswordVisibility_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <TextBlock Grid.Column="2" Text="👁" Foreground="#64748B" FontSize="15" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <TextBlock Text="Xác nhận mật khẩu" Foreground="#334155" FontWeight="Medium" FontSize="14" Margin="0,0,0,8"/>
                <Border Height="46" CornerRadius="14" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" Margin="0,0,0,14">
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="34"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔒" Foreground="#64748B" FontSize="17" VerticalAlignment="Center"/>
                        <PasswordBox x:Name="ConfirmPasswordInput"
                                     Grid.Column="1"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#0F172A"
                                     FontSize="14"
                                     VerticalContentAlignment="Center"
                                     PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>
                        <TextBox x:Name="VisibleConfirmPasswordInput"
                                 Grid.Column="1"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#0F172A"
                                 FontSize="14"
                                 VerticalContentAlignment="Center"
                                 Visibility="Collapsed"
                                 TextChanged="VisibleConfirmPasswordInput_TextChanged"/>
                        <Button Grid.Column="2"
                                Panel.ZIndex="2"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                Cursor="Hand"
                                Focusable="False"
                                Click="ToggleConfirmPasswordVisibility_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <TextBlock Grid.Column="2" Text="👁" Foreground="#64748B" FontSize="15" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <TextBlock Text="{Binding Message}"
                           Foreground="#EF4444"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"
                           HorizontalAlignment="Center"/>

                <Button Content="Đăng ký"
                        Style="{StaticResource RoundedButton}"
                        Command="{Binding RegisterCommand}"
                        Margin="0,0,0,20"/>

                <TextBlock HorizontalAlignment="Center" FontSize="14" Foreground="#64748B">
                    <Run Text="Đã có tài khoản? "/>
                    <Hyperlink Command="{Binding ShowLoginCommand}"
                               Foreground="#06B6D4"
                               FontWeight="SemiBold"
                               TextDecorations="{x:Null}">
                        Đăng nhập
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
