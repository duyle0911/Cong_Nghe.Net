<UserControl x:Class="QuanLyTaiChinhCaNhan_Nhom06.Views.ReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <UserControl.Resources>
        <Style x:Key="ReportCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style x:Key="ReportSectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="PeriodButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
        </Style>
    </UserControl.Resources>

    <StackPanel Background="Transparent">
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Command="{Binding ExportCommand}"
                    Style="{StaticResource RoundedButton}"
                    Height="40"
                    Padding="15,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Download" Width="17" Height="17" Margin="0,0,7,0"/>
                    <TextBlock Text="Xuất báo cáo"/>
                </StackPanel>
            </Button>
        </Grid>

        <Border Style="{StaticResource ReportCard}" Padding="14" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="145"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="145"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <materialDesign:PackIcon Kind="CalendarMonth"
                                         Width="19"
                                         Height="19"
                                         Foreground="{StaticResource SecondaryTextBrush}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,8,0"/>
                <DatePicker Grid.Column="1" SelectedDate="{Binding FromDate}" MinHeight="38"/>
                <TextBlock Grid.Column="3" Text="đến" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker Grid.Column="4" SelectedDate="{Binding ToDate}" MinHeight="38"/>
                <Button Grid.Column="6"
                        Content="Lọc"
                        Command="{Binding FilterCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Height="40"
                        Padding="18,0"
                        Margin="10,0,0,0"/>

                <StackPanel Grid.Column="8" Orientation="Horizontal">
                    <Button Content="Tháng" Command="{Binding SelectPeriodCommand}" CommandParameter="Month" Style="{StaticResource PeriodButton}"/>
                    <Button Content="Quý" Command="{Binding SelectPeriodCommand}" CommandParameter="Quarter" Style="{StaticResource PeriodButton}"/>
                    <Button Content="Năm" Command="{Binding SelectPeriodCommand}" CommandParameter="Year" Style="{StaticResource PeriodButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <UniformGrid Columns="3" Margin="0,0,0,14">
            <Border Style="{StaticResource ReportCard}" Margin="0,0,12,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="44"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Tổng thu nhập" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                        <TextBlock Text="{Binding Income}" Foreground="#10B981" FontSize="22" FontWeight="Bold" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding IncomeChangeText}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" Margin="0,8,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" Width="38" Height="38" CornerRadius="12" Background="#10B981">
                        <materialDesign:PackIcon Kind="TrendingUp" Foreground="White" Width="19" Height="19" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <Border Style="{StaticResource ReportCard}" Margin="0,0,12,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="44"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Tổng chi tiêu" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                        <TextBlock Text="{Binding Expense}" Foreground="{StaticResource DangerBrush}" FontSize="22" FontWeight="Bold" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding ExpenseChangeText}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" Margin="0,8,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" Width="38" Height="38" CornerRadius="12" Background="#FB923C">
                        <materialDesign:PackIcon Kind="TrendingDown" Foreground="White" Width="19" Height="19" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <Border Style="{StaticResource ReportCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="44"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Tổng tiết kiệm" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                        <TextBlock Text="{Binding Balance}" Foreground="#0EA5E9" FontSize="22" FontWeight="Bold" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding BalanceChangeText}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" Margin="0,8,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" Width="38" Height="38" CornerRadius="12" Background="#0EA5E9">
                        <materialDesign:PackIcon Kind="ChartDonutVariant" Foreground="White" Width="19" Height="19" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
        </UniformGrid>

        <Border Style="{StaticResource ReportCard}" Margin="0,0,0,14">
            <StackPanel>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Xu hướng thu chi" Style="{StaticResource ReportSectionTitle}"/>
                        <TextBlock Text="{Binding CashFlowChartSummary}"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="12"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                            <Ellipse Width="10" Height="10" Fill="#10B981" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Thu nhập" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Fill="#FB7185" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Chi tiêu" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
                <lvc:CartesianChart Height="320"
                                    Margin="0,4,0,0"
                                    Series="{Binding CashFlowSeries}"
                                    XAxes="{Binding XAxes}"
                                    YAxes="{Binding CashFlowYAxes}"
                                    LegendPosition="Bottom"
                                    TooltipPosition="Top"
                                    LegendTextSize="13"
                                    TooltipTextSize="13"/>
            </StackPanel>
        </Border>

        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource ReportCard}">
                <StackPanel>
                    <TextBlock Text="Phân bổ chi tiêu theo danh mục" Style="{StaticResource ReportSectionTitle}" Margin="0,0,0,10"/>
                    <Grid Height="215">
                        <lvc:PieChart Series="{Binding CategorySeries}" LegendPosition="Right"/>
                        <TextBlock Text="Chưa có dữ liệu chi tiêu."
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasData}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource ReportCard}">
                <StackPanel>
                    <TextBlock Text="Chi tiêu hàng ngày" Style="{StaticResource ReportSectionTitle}" Margin="0,0,0,10"/>
                    <lvc:CartesianChart Height="215"
                                        Series="{Binding DailyExpenseSeries}"
                                        XAxes="{Binding DailyXAxes}"
                                        LegendPosition="Hidden"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Style="{StaticResource ReportCard}">
            <StackPanel>
                <TextBlock Text="Nhận xét &amp; đề xuất" Style="{StaticResource ReportSectionTitle}" Margin="0,0,0,12"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1" CornerRadius="12" Padding="13">
                        <StackPanel>
                            <TextBlock Text="Điểm tốt" Foreground="#059669" FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock Text="{Binding PositiveInsight}" Foreground="#047857" FontSize="11" TextWrapping="Wrap" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1" CornerRadius="12" Padding="13">
                        <StackPanel>
                            <TextBlock Text="Cần chú ý" Foreground="#EA580C" FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock Text="{Binding WarningInsight}" Foreground="#C2410C" FontSize="11" TextWrapping="Wrap" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
