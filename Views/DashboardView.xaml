<UserControl x:Class="QuanLyTaiChinhCaNhan_Nhom06.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <UserControl.Resources>
        <Style x:Key="DashboardCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style x:Key="DashboardSectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="ChartToolTip" TargetType="ToolTip">
            <Setter Property="Placement" Value="MousePoint"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HasDropShadow" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel Background="Transparent">
        <UniformGrid Columns="4" Margin="0,0,0,16">
            <Border Style="{StaticResource DashboardCard}" Margin="0,0,12,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="46"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Tổng thu" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                        <TextBlock Text="{Binding TotalIncome}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="21" FontWeight="Bold" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding IncomeChangeText}" Foreground="#10B981" FontSize="11" Margin="0,9,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" Width="40" Height="40" CornerRadius="13" Background="#10B981">
                        <materialDesign:PackIcon Kind="TrendingUp" Foreground="White" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <Border Style="{StaticResource DashboardCard}" Margin="0,0,12,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="46"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Tổng chi" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                        <TextBlock Text="{Binding TotalExpense}" Foreground="{StaticResource DangerBrush}" FontSize="21" FontWeight="Bold" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding ExpenseChangeText}" Foreground="{StaticResource DangerBrush}" FontSize="11" Margin="0,9,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" Width="40" Height="40" CornerRadius="13" Background="#FB923C">
                        <materialDesign:PackIcon Kind="TrendingDown" Foreground="White" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <Border Style="{StaticResource DashboardCard}" Margin="0,0,12,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="46"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Số dư" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                        <TextBlock Text="{Binding Balance}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="21" FontWeight="Bold" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding BalanceChangeText}" Foreground="#0EA5E9" FontSize="11" Margin="0,9,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" Width="40" Height="40" CornerRadius="13" Background="#0EA5E9">
                        <materialDesign:PackIcon Kind="Wallet" Foreground="White" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <Border Style="{StaticResource DashboardCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="46"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Tiết kiệm" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                        <TextBlock Text="{Binding Savings}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="21" FontWeight="Bold" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding SavingsChangeText}" Foreground="#10B981" FontSize="11" Margin="0,9,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" Width="40" Height="40" CornerRadius="13" Background="#06B6D4">
                        <materialDesign:PackIcon Kind="CurrencyUsd" Foreground="White" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
        </UniformGrid>

        <Border Background="#FEF3C7"
                BorderBrush="#F59E0B"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14"
                Margin="0,0,0,16">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasBudgetAlerts}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel>
                <materialDesign:PackIcon Kind="AlertCircleOutline"
                                         DockPanel.Dock="Left"
                                         Foreground="#A16207"
                                         Width="20"
                                         Height="20"
                                         Margin="0,0,10,0"/>
                <StackPanel>
                    <TextBlock Text="Cảnh báo ngân sách"
                               Foreground="#92400E"
                               FontWeight="SemiBold"
                               FontSize="13"/>
                    <TextBlock Text="{Binding BudgetAlertText}"
                               Foreground="#A16207"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource DashboardCard}" MinHeight="360">
                <StackPanel>
                    <TextBlock Text="Thu chi 6 tháng gần nhất" Style="{StaticResource DashboardSectionTitle}" Margin="0,0,0,12"/>
                    <Border Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            Margin="0">
                        <Grid Height="228">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="180"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <TextBlock Text="{Binding CashFlowMaxLabel}"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           FontSize="11"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Top"
                                           Visibility="Collapsed"/>
                                <TextBlock Text="{Binding CashFlowMidLabel}"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           FontSize="11"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0"/>
                                <TextBlock Text="0"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           FontSize="11"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Bottom"
                                           Margin="0,0,12,-4"/>
                            </Grid>

                            <Grid Grid.Row="0" Grid.Column="1">
                                <Border Height="1" Background="#E2E8F0" VerticalAlignment="Center"/>
                                <Border Height="1" Background="#CBD5E1" VerticalAlignment="Bottom"/>

                                <ItemsControl ItemsSource="{Binding CashFlowItems}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="1"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Width="70"
                                                  Height="180"
                                                  Margin="6,0"
                                                  Background="Transparent"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Bottom">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="28"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="28"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="1"
                                                        Height="{Binding IncomeBarHeight}"
                                                        Background="#10B981"
                                                        CornerRadius="4,4,0,0"
                                                        Cursor="Hand"
                                                        ToolTipService.InitialShowDelay="0"
                                                        VerticalAlignment="Bottom">
                                                    <Border.ToolTip>
                                                        <ToolTip Style="{StaticResource ChartToolTip}">
                                                            <Border Background="{DynamicResource MutedCardBrush}"
                                                                    BorderBrush="{DynamicResource BorderBrushSoft}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="10"
                                                                    Padding="12,9">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Ellipse Width="10" Height="10" Fill="#10B981" VerticalAlignment="Center" Margin="0,0,9,0"/>
                                                                    <TextBlock Text="Thu" Foreground="{StaticResource SecondaryTextBrush}" FontSize="13" Margin="0,0,12,0"/>
                                                                    <TextBlock Text="{Binding IncomeAmountText}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </ToolTip>
                                                    </Border.ToolTip>
                                                </Border>
                                                <Border Grid.Column="3"
                                                        Height="{Binding ExpenseBarHeight}"
                                                        Background="#FB7185"
                                                        CornerRadius="4,4,0,0"
                                                        Cursor="Hand"
                                                        ToolTipService.InitialShowDelay="0"
                                                        VerticalAlignment="Bottom">
                                                    <Border.ToolTip>
                                                        <ToolTip Style="{StaticResource ChartToolTip}">
                                                            <Border Background="{DynamicResource MutedCardBrush}"
                                                                    BorderBrush="{DynamicResource BorderBrushSoft}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="10"
                                                                    Padding="12,9">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Ellipse Width="10" Height="10" Fill="#FB7185" VerticalAlignment="Center" Margin="0,0,9,0"/>
                                                                    <TextBlock Text="Chi" Foreground="{StaticResource SecondaryTextBrush}" FontSize="13" Margin="0,0,12,0"/>
                                                                    <TextBlock Text="{Binding ExpenseAmountText}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </ToolTip>
                                                    </Border.ToolTip>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>

                            <ItemsControl Grid.Row="1"
                                          Grid.Column="1"
                                          ItemsSource="{Binding CashFlowItems}"
                                          Margin="0,10,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Label}"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   FontSize="10"
                                                   TextAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,16,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,22,0">
                            <Ellipse Width="10" Height="10" Fill="#10B981" VerticalAlignment="Center"/>
                            <TextBlock Text="Thu"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       FontSize="13"
                                       Margin="7,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Fill="#FB7185" VerticalAlignment="Center"/>
                            <TextBlock Text="Chi"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       FontSize="13"
                                       Margin="7,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource DashboardCard}" MinHeight="360">
                <StackPanel>
                    <TextBlock Text="Phân bổ chi tiêu" Style="{StaticResource DashboardSectionTitle}" Margin="0,0,0,12"/>
                    <Grid Height="292">
                        <lvc:PieChart Series="{Binding ExpenseSeries}"
                                      LegendPosition="Bottom"
                                      TooltipPosition="Top"
                                      LegendTextSize="14"
                                      TooltipTextSize="14"
                                      Margin="0,4,0,0"/>
                        <TextBlock Text="Chưa có dữ liệu chi tiêu."
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasExpenseChart}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource DashboardCard}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <TextBlock DockPanel.Dock="Right"
                                   Text="Tháng hiện tại"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Giao dịch gần đây" Style="{StaticResource DashboardSectionTitle}"/>
                    </DockPanel>

                    <Grid>
                        <ItemsControl ItemsSource="{Binding RecentTransactions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource MutedCardBrush}"
                                            CornerRadius="12"
                                            Padding="11"
                                            Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="36"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="28" Height="28" CornerRadius="14" Background="{Binding SoftAccentBrush}">
                                                <TextBlock Text="{Binding IconText}"
                                                           Foreground="{Binding AccentBrush}"
                                                           FontWeight="Bold"
                                                           FontSize="16"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Description}" Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold" FontSize="12"/>
                                                <TextBlock Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" Margin="0,3,0,0">
                                                    <Run Text="{Binding CategoryName, Mode=OneWay}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding DateText, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding AmountText}"
                                                       Foreground="{Binding AccentBrush}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Chưa có giao dịch trong tháng này."
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasTransactions}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource DashboardCard}">
                <StackPanel>
                    <TextBlock Text="Tiến độ ngân sách" Style="{StaticResource DashboardSectionTitle}" Margin="0,0,0,14"/>
                    <Grid>
                        <ItemsControl ItemsSource="{Binding Budgets}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,13">
                                        <DockPanel Margin="0,0,0,6">
                                            <TextBlock Text="{Binding AmountText}"
                                                       DockPanel.Dock="Right"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       FontSize="11"/>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12"/>
                                        </DockPanel>
                                        <ProgressBar Value="{Binding UsedPercent, Mode=OneWay}"
                                                     Maximum="100"
                                                     Height="7"
                                                     Foreground="{Binding ProgressBrush}"
                                                     Background="#E2E8F0"/>
                                        <TextBlock Text="{Binding ProgressText}"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   FontSize="11"
                                                   Margin="0,5,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Chưa có ngân sách đang hoạt động."
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasBudgets}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </StackPanel>
</UserControl>
