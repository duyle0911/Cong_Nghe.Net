<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <FontFamily x:Key="AppFont">Segoe UI</FontFamily>

    <SolidColorBrush x:Key="BackgroundBrush" Color="#EEF4FF"/>
    <SolidColorBrush x:Key="CardBgBrush" Color="#FDFEFF"/>
    <SolidColorBrush x:Key="MutedCardBrush" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="BorderBrushSoft" Color="#E2E8F0"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#CBD5E1"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="#E0F2FE"/>
    <SolidColorBrush x:Key="SidebarPressedBrush" Color="#BAE6FD"/>
    <SolidColorBrush x:Key="SidebarUserBrush" Color="#E0F2FE"/>
    <SolidColorBrush x:Key="SidebarUserBorderBrush" Color="#BAE6FD"/>

    <SolidColorBrush x:Key="PrimaryBrush" Color="#06B6D4"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#0EA5E9"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="#10B981"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#22D3EE"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#EF4444"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#EAB308"/>

    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#0F172A"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#64748B"/>
    <SolidColorBrush x:Key="LightTextBrush" Color="#94A3B8"/>

    <DropShadowEffect x:Key="CardShadow" Color="#CBD5E1" BlurRadius="35" ShadowDepth="10" Opacity="0.45"/>
    <DropShadowEffect x:Key="LightShadow" Color="#CBD5E1" BlurRadius="22" ShadowDepth="6" Opacity="0.35"/>
    <DropShadowEffect x:Key="ButtonShadow" Color="#06B6D4" BlurRadius="24" ShadowDepth="4" Opacity="0.35"/>

    <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#06B6D4" Offset="0"/>
        <GradientStop Color="#0EA5E9" Offset="0.5"/>
        <GradientStop Color="#10B981" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="BackgroundGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#EEF4FF" Offset="0"/>
        <GradientStop Color="#E0EAFF" Offset="0.45"/>
        <GradientStop Color="#F5F3FF" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SidebarGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FDFEFF" Offset="0"/>
        <GradientStop Color="#F8FAFC" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SuccessGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#10B981" Offset="0"/>
        <GradientStop Color="#34D399" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="DangerGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#EF4444" Offset="0"/>
        <GradientStop Color="#FB923C" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CardSoftGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#F8FAFC" Offset="1"/>
    </LinearGradientBrush>

    <Style TargetType="Control">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
    </Style>

    <ControlTemplate x:Key="RoundedButtonTemplate" TargetType="Button">
        <Border x:Name="Root"
                CornerRadius="14"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}">
            <ContentPresenter HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Margin="{TemplateBinding Padding}"/>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Property="Opacity" Value="0.88"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Root" Property="Opacity" Value="0.72"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="RoundedButton" TargetType="Button">
        <Setter Property="Height" Value="48"/>
        <Setter Property="Padding" Value="20,0"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="{DynamicResource PrimaryGradient}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template" Value="{StaticResource RoundedButtonTemplate}"/>
        <Setter Property="Effect" Value="{StaticResource ButtonShadow}"/>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Height" Value="44"/>
        <Setter Property="Padding" Value="18,0"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
        <Setter Property="Background" Value="{DynamicResource SidebarHoverBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template" Value="{StaticResource RoundedButtonTemplate}"/>
    </Style>

    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
        <Setter Property="Background" Value="{StaticResource DangerGradient}"/>
    </Style>

    <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
        <Setter Property="Background" Value="{StaticResource SuccessGradient}"/>
        <Setter Property="Effect" Value="{StaticResource ButtonShadow}"/>
    </Style>

    <Style x:Key="ShellCard" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource CardSoftGradient}"/>
        <Setter Property="CornerRadius" Value="22"/>
        <Setter Property="Padding" Value="24"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Effect" Value="{StaticResource LightShadow}"/>
    </Style>

    <Style x:Key="CardTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        <Setter Property="Margin" Value="0,0,0,18"/>
    </Style>

    <Style x:Key="MutedLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
    </Style>

    <Style x:Key="SidebarButton" TargetType="Button">
        <Setter Property="Height" Value="48"/>
        <Setter Property="Margin" Value="0,6"/>
        <Setter Property="Padding" Value="16,0"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            CornerRadius="16"
                            Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource SidebarHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource SidebarPressedBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="GridLinesVisibility" Value="None"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="RowHeight" Value="50"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        <Setter Property="RowBackground" Value="{DynamicResource CardBgBrush}"/>
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource MutedCardBrush}"/>
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="BorderThickness" Value="0"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource SidebarHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource SidebarPressedBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource MutedCardBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Height" Value="44"/>
        <Setter Property="Padding" Value="14,0"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="MinHeight" Value="46"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <Style TargetType="PasswordBox">
        <Setter Property="MinHeight" Value="46"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- Keep the Material Design templates. Defining an implicit style without
         BasedOn falls back to the native WPF template, whose inner editor and
         drop-down button stay white when the application switches to dark mode. -->
    <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignComboBox}">
        <Setter Property="MinHeight" Value="46"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
    </Style>

    <Style TargetType="DatePicker" BasedOn="{StaticResource MaterialDesignDatePicker}">
        <Setter Property="MinHeight" Value="46"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
    </Style>


    <Style x:Key="ColorPaletteListBox" TargetType="ListBox">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
        <Setter Property="MinHeight" Value="74"/>
        <Setter Property="MinWidth" Value="190"/>
        <Setter Property="Padding" Value="8,8,2,1"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="MaxHeight" Value="112"/>
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ColorPaletteItem" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0,0,7,7"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Ring"
                            Width="30"
                            Height="30"
                            CornerRadius="15"
                            Padding="3"
                            BorderBrush="Transparent"
                            BorderThickness="2"
                            Background="Transparent">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Ring" Property="BorderBrush" Value="#94A3B8"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Ring" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <DataTemplate x:Key="ColorPaletteItemTemplate">
        <Border Width="22"
                Height="22"
                CornerRadius="11"
                Background="{Binding PreviewBrush}"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                ToolTip="{Binding DisplayName}"/>
    </DataTemplate>
</ResourceDictionary>
